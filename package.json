{
  "name": "bachelorette-scavenger-hunt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "cms:build": "node scripts/build-content-from-cms.mjs --version sheet-cms-2026-07-09",
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
